---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Banner from "../components/Banner.astro";
import { getEntry, render } from "astro:content";

const policy = await getEntry("privacy", "privacy-polic");
if (!policy) {
	throw new Error("Missing entry: src/content/privacy/privacy-polic.md");
}
const { Content } = await render(policy);
---

<BaseLayout title={policy.data.title} description={policy.data.description}>
	<Header slot="header" />

	<Banner title="Политика конфиденциальности" />

	<section class="py-section">
		<div class="mx-auto max-w-3xl px-4 sm:px-6">
			<article class="prose prose-lg max-w-none prose-h1:hidden prose-headings:font-heading prose-headings:uppercase prose-a:text-primary-light hover:prose-a:text-primary">
				<Content />
			</article>
		</div>
	</section>

	<Footer slot="footer" />
</BaseLayout>
