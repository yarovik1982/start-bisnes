---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Banner from "../components/Banner.astro";
import CTA from "../components/CTA.astro";
import { Image } from "astro:assets";
import { brand } from "../config/brand";

const team = [
	{
		name: "John Smith",
		role: "Founder & Lead Technician",
		image:
			"https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=400&q=80",
	},
	{
		name: "Maria Garcia",
		role: "Operations Manager",
		image:
			"https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=400&q=80",
	},
	{
		name: "David Chen",
		role: "Senior Technician",
		image:
			"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=400&q=80",
	},
];
---

<BaseLayout
	title="About Us"
	description={`Learn about ${brand.name} — our story, team, and commitment to quality service.`}>
	<Header slot="header" />

	<Banner title="About Us" />

	<!-- Story -->
	<section class="py-section">
		<div
			class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14">
			<div class="overflow-hidden rounded-lg shadow-lg">
				<Image
					src="https://images.unsplash.com/photo-1521737711867-e3b97375f902?w=800&q=80"
					alt="Our team planning a project together"
					width={800}
					height={600}
					loading="lazy"
					class="size-full object-cover"
				/>
			</div>
			<div class="space-y-5">
				<span class="text-topper font-bold uppercase tracking-widest text-accent"
					>Наша история</span
				>
				<h2 class="font-heading text-h2 font-bold uppercase text-text">
					Основано на доверии, движимо качеством.
				</h2>
				<p class="text-text-muted leading-relaxed">
					То, что началось как работа одного человека, трансформировалось в надёжную
					команду единомышленников. Уже более 15 лет мы помогаем бизнесу, выполняя
					качественную и надёжную работу — и планируем делать это ещё долгие годы.
				</p>
				<p class="text-text-muted leading-relaxed">
					Каждый член нашей команды имеет лицензию, страховку и прошёл проверку. Мы относимся к вашему имуществу так же бережно, как к своему собственному, и гарантируем качество каждой выполненной работы.
				</p>
			</div>
		</div>
	</section>

	<!-- Team -->
	<section class="bg-surface py-section">
		<div class="mx-auto max-w-site px-4 sm:px-6">
			<div class="mx-auto mb-10 max-w-2xl text-center">
				<span class="text-topper font-bold uppercase tracking-widest text-accent"
					>Наша команда</span
				>
				<h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">
					Познакомьтесь с нашей командой.

				</h2>
			</div>

			<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
				{
					team.map(({ name, role, image }) => (
						<div class="overflow-hidden rounded-lg bg-background shadow-sm">
							<Image
								src={image}
								alt={name}
								width={400}
								height={400}
								loading="lazy"
								class="aspect-square w-full object-cover"
							/>
							<div class="p-5">
								<h3 class="font-heading text-lg font-semibold text-text">{name}</h3>
								<p class="text-sm text-text-muted">{role}</p>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<CTA />

	<Footer slot="footer" />
</BaseLayout>
