---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Banner from "../components/Banner.astro";
import CTA from "../components/CTA.astro";
import { brand } from "../config/brand";
import { client } from "../data/client";

const reviews = [
	{
		quote:
			"Они приехали вовремя, всё подробно объяснили и закончили работу быстрее, чем ожидалось. Лучший сервис, с которым нам приходилось сталкиваться.",
		name: "Светлана",
		location: "Воронеж",
		rating: 5,
	},
	{
		quote:
			"Честные цены и отличное качество работы. Уже обращался к ним для трёх разных проектов — и каждый раз результат на высоте.",
		name: "Макс Ворон",
		location: "Беларусь",
		rating: 5,
	},
	{
		quote:
			"На наш экстренный вызов ответили буквально за несколько минут. Проблему устранили ещё до ужина. Очень надёжная команда.",
		name: "Анна",
		location: "Екатеринбург",
		rating: 5,
	},
	{
		quote:
			"Ремонт получился даже лучше, чем мы представляли. Профессионально, аккуратно и без выхода за бюджет. Мы в полном восторге.",
		name: "Tom & Beth P.",
		location: "Boulder, CO",
		rating: 5,
	},
	{
		quote:
			"Отличная коммуникация от начала до конца. Нам отправляли фотографии процесса и идеально убрали всё после завершения работ.",
		name: "Anita W.",
		location: "Littleton, CO",
		rating: 5,
	},
	{
		quote:
			"Особенно понравились прозрачные цены — никаких скрытых платежей и неожиданных доплат. Сейчас такое редко встретишь. Очень рекомендую.",
		name: "Marcus D.",
		location: "Arvada, CO",
		rating: 5,
	},
];
---

<BaseLayout
	title="Reviews"
	description={`Read reviews and testimonials from ${brand.name} customers. See why homeowners trust us for their projects.`}
	schema={{
		"@context": "https://schema.org",
		"@type": "LocalBusiness",
		name: client.name,
		aggregateRating: {
			"@type": "AggregateRating",
			ratingValue: "5",
			reviewCount: String(reviews.length),
			bestRating: "5",
		},
	}}>
	<Header slot="header" />

	<Banner title="Отзывы клиентов" />

	<section class="py-section">
		<div class="mx-auto max-w-site px-4 sm:px-6">
			<div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
				<h2 class="font-heading text-h2 font-bold uppercase text-text">
					Что говорят наши клиенты
				</h2>
				<p class="mt-3 text-text-muted leading-relaxed">
					Не верьте нам на слово — лучше послушайте клиентов, которым мы уже
					помогли.
				</p>
			</div>

			<div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
				{
					reviews.map(({ quote, name, location, rating = 5 }) => (
						<div class="flex flex-col rounded-lg border border-border bg-background p-6 shadow-sm">
							<div
								class="mb-4 flex gap-0.5"
								aria-label={`Rated ${rating} out of 5 stars`}>
								{Array.from({ length: 5 }).map((_, i) => (
									<svg
										class:list={["size-5", i < rating ? "text-accent" : "text-border"]}
										fill="currentColor"
										viewBox="0 0 20 20"
										aria-hidden="true">
										<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
									</svg>
								))}
							</div>
							<blockquote class="flex-1 text-text-muted leading-relaxed">
								&ldquo;{quote}&rdquo;
							</blockquote>
							<div class="mt-4 border-t border-border pt-4">
								<p class="font-semibold text-text">{name}</p>
								<p class="text-sm text-text-muted">{location}</p>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<CTA />

	<Footer slot="footer" />
</BaseLayout>
