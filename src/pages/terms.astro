---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Banner from "../components/Banner.astro";
import { getEntry, render } from "astro:content";

const terms = await getEntry("terms", "terms");
if (!terms) {
	throw new Error("Missing entry: src/content/terms/terms.md");
}
const { Content } = await render(terms);
---

<BaseLayout title={terms.data.title} description={terms.data.description}>
	<Header slot="header" />

	<Banner title="Политика конфиденциальности" />

	<section class="py-section">
		<div class="mx-auto max-w-3xl px-4 sm:px-6">
			<article
				class="prose prose-lg max-w-none prose-h1:hidden prose-headings:font-heading prose-headings:uppercase prose-a:text-primary-light hover:prose-a:text-primary">
				<Content />
			</article>
		</div>
	</section>

	<Footer slot="footer" />
</BaseLayout>
