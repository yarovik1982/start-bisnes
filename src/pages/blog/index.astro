---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import CTA from '../../components/CTA.astro';
import { getCollection } from 'astro:content';
import { brand } from '../../config/brand';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description={`Tips, guides, and news from ${brand.name}. Stay informed about home maintenance and improvement.`}>
  <Header slot="header" />

  <Banner title="Blog" />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      {posts.length === 0 ? (
        <p class="text-center text-text-muted">No posts yet. Check back soon!</p>
      ) : (
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => {
            const formattedDate = post.data.date.toLocaleDateString('ru-RU', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });
            return (
              <article class="group flex flex-col overflow-hidden rounded-lg border border-border bg-background shadow-sm transition-shadow hover:shadow-md">
                <div class="flex flex-1 flex-col p-6">
                  <div class="flex items-center gap-2 text-sm text-text-muted">
                    <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
                    {post.data.tags.length > 0 && (
                      <>
                        <span aria-hidden="true">&bull;</span>
                        <span>{post.data.tags[0]}</span>
                      </>
                    )}
                  </div>
                  <h2 class="mt-3 font-heading text-h3 font-semibold text-text group-hover:text-primary transition-colors">
                    <a href={`/blog/${post.id}`} class="after:absolute after:inset-0 relative">
                      {post.data.title}
                    </a>
                  </h2>
                   <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">
                     {post.data.description}
                   </p>
                  <a
                    href={`/blog/${post.id}`}
                    class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary transition-colors hover:text-primary-light"
                  >
                    Читать
                    <svg class="size-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
