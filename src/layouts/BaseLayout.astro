---
/**
 * Base layout — wraps every page.
 *
 * Astro 6 features used:
 *  • <Font />         — built-in font optimizer from astro.config.mjs fonts array
 *  • <ClientRouter /> — client-side navigation with CSS transition animations
 */
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { brand } from '../config/brand';
import { client } from '../data/client';
import BannerCookies from '../components/BannerCookies.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schema?: Record<string, unknown>;
}

const {
  title = brand.name,
  description = brand.description,
  image = '/og-image.png',
  schema,
} = Astro.props;

const pageTitle = title === brand.name ? title : `${title} — ${brand.name}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? brand.url);
---

<html lang={brand.locale.split('_')[0]} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={image} />
    <meta property="og:locale"      content={brand.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={image} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Fonts -->
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body"    preload />

    <!-- JSON-LD Structured Data -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- FOUC prevention for dark mode -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark-mode');
        }
      })();
    </script>

    <slot name="head" />
    <ClientRouter />
  </head>

  <body class="bg-background text-text font-body antialiased">
    <a
      class="sr-only focus:not-sr-only focus:absolute focus:z-99999 focus:bg-primary focus:text-primary-fg focus:px-4 focus:py-2 focus:rounded-md"
      href="#main"
    >
      Skip to main content
    </a>

    <slot name="header" />

    <main id="main">
      <slot />
    </main>

    <slot name="footer" />
    <BannerCookies />
  </body>
</html>
