---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
}

const { title, description, date, author = 'Team' } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />

  <!-- Post hero -->
  <section class="bg-primary py-14 sm:py-16 lg:py-20">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <nav aria-label="Хлебные крошки" class="mb-4">
        <ol class="flex items-center gap-1.5 text-sm text-primary-fg/60">
          <li><a href="/" class="transition-colors hover:text-primary-fg">Главная</a></li>
          <li class="flex items-center gap-1.5">
            <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            <a href="/blog" class="transition-colors hover:text-primary-fg">Блог</a>
          </li>
          <li class="flex items-center gap-1.5">
            <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            <span aria-current="page" class="text-primary-fg">{title}</span>
          </li>
        </ol>
      </nav>

      <h1 class="font-heading text-h1 font-bold uppercase text-primary-fg">{title}</h1>
      <div class="mt-3 flex items-center gap-3 text-sm text-primary-fg/70">
        <span>{author}</span>
        <span aria-hidden="true">&bull;</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    </div>
  </section>

  <!-- Post content -->
  <section class="py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <article class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:uppercase prose-a:text-primary-light hover:prose-a:text-primary">
        <slot />
      </article>

      <div class="mt-10 border-t border-border pt-6">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm font-semibold text-primary transition-colors hover:text-primary-light"
        >
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Back to Blog
        </a>
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
