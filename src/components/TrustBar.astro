---
interface TrustItem {
  label: string;
  value?: string;
}

interface Props {
  items?: TrustItem[];
}

const { items =[
  { label: 'Лицензия' },
  { label: 'Полная страховка' },
  { label: 'Опыт работы', value: '15+' },
  { label: 'Выполнено проектов', value: '2,500+' },
] } = Astro.props;
---

<section class="border-y border-border bg-surface" aria-label="Trust signals">
  <div class="mx-auto max-w-site overflow-x-auto px-4 py-5 sm:px-6 sm:py-6">
    <ul class="flex flex-wrap items-center justify-between gap-6 sm:gap-8 lg:justify-center lg:gap-16" role="list">
      {items.map(({ label, value }) => (
        <li class="flex shrink-0 items-center gap-2.5 text-sm sm:text-base">
          <svg class="size-5 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span class="font-heading font-semibold text-text">
            {value && <span class="text-primary">{value} </span>}
            {label}
          </span>
        </li>
      ))}
    </ul>
  </div>
</section>
