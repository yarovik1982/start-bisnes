---
import { brand } from "../config/brand";
import { client } from "../data/client";

const year = new Date().getFullYear();

const navCols = [
	{
		title: "Компания",
		links: [
			{ label: "О нас", href: "/about" },
			{ label: "Услуги", href: "/services" },
			{ label: "Отзывы", href: "/reviews" },
			{ label: "Блог", href: "/blog" },
		],
	},
	{
		title: "Поддержка",
		links: [
			{ label: "Контакты", href: "/contact" },
			{ label: "Конфиденциальность", href: "/privacy" },
			{ label: "Условия использования", href: "/terms" },
		],
	},
];
---

<footer class="bg-dark text-surface/80" transition:persist>
	<div class="mx-auto max-w-site px-4 py-12 sm:px-6 lg:py-16">
		<div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
			<!-- Brand -->
			<div class="sm:col-span-2 lg:col-span-1">
				<a
					href="/"
					class="font-heading text-lg font-bold uppercase tracking-wide text-white">
					{brand.name}
				</a>
				<p class="mt-3 max-w-xs text-sm leading-relaxed">
					{brand.tagline}
				</p>

				<!-- Social links -->
				<div class="mt-5 flex items-center gap-4">
					{
						client.socials.facebook && (
							<a
								href={client.socials.facebook}
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Facebook"
								class="text-surface/60 transition-colors hover:text-white">
								<svg
									class="size-5"
									fill="currentColor"
									viewBox="0 0 24 24"
									aria-hidden="true">
									<path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
								</svg>
							</a>
						)
					}
					{
						client.socials.instagram && (
							<a
								href={client.socials.instagram}
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Instagram"
								class="text-surface/60 transition-colors hover:text-white">
								<svg
									class="size-5"
									fill="currentColor"
									viewBox="0 0 24 24"
									aria-hidden="true">
									<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
								</svg>
							</a>
						)
					}
					{
						client.socials.telegram && (
							<a
								href={client.socials.telegram}
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Telegram"
								class="text-surface/60 transition-colors hover:text-white">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="24"
									height="24"
									fill="currentColor"
									class="size-5"
									viewBox="0 0 16 16"
									aria-hidden="true">
									<path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M8.287 5.906q-1.168.486-4.666 2.01-.567.225-.595.442c-.03.243.275.339.69.47l.175.055c.408.133.958.288 1.243.294q.39.01.868-.32 3.269-2.206 3.374-2.23c.05-.012.12-.026.166.016s.042.12.037.141c-.03.129-1.227 1.241-1.846 1.817-.193.18-.33.307-.358.336a8 8 0 0 1-.188.186c-.38.366-.664.64.015 1.088.327.216.589.393.85.571.284.194.568.387.936.629q.14.092.27.187c.331.236.63.448.997.414.214-.02.435-.22.547-.82.265-1.417.786-4.486.906-5.751a1.4 1.4 0 0 0-.013-.315.34.34 0 0 0-.114-.217.53.53 0 0 0-.31-.093c-.3.005-.763.166-2.984 1.09" />
								</svg>
							</a>
						)
					}
				</div>
			</div>

			<!-- Nav columns -->
			{
				navCols.map((col) => (
					<div>
						<h3 class="text-sm font-bold uppercase tracking-wider text-white">
							{col.title}
						</h3>
						<ul class="mt-3 space-y-2">
							{col.links.map(({ label, href }) => (
								<li>
									<a href={href} class="text-sm transition-colors hover:text-white">
										{label}
									</a>
								</li>
							))}
						</ul>
					</div>
				))
			}

			<!-- Contact info -->
			<div>
				<h3 class="text-sm font-bold uppercase tracking-wider text-white">
					Контакты
				</h3>
				<ul class="mt-3 space-y-2 text-sm">
					<li>
						<a
							href={`tel:${client.phoneForTel}`}
							class="transition-colors hover:text-white">
							{client.phoneFormatted}
						</a>
					</li>
					<li>
						<a
							href={`mailto:${client.email}`}
							class="transition-colors hover:text-white">
							{client.email}
						</a>
					</li>
					<li>
						<a
							href={client.address.mapLink}
							target="_blank"
							rel="noopener noreferrer"
							class="transition-colors hover:text-white">
							{client.address.zip}, {client.address.state}<br />
							{client.address.city}<br/>
							{client.address.lineOne}
						</a>
					</li>
				</ul>
			</div>
		</div>

		<!-- Copyright -->
		<div class="mt-10 border-t border-surface/10 pt-6 text-center text-sm">
			&copy; {year}
			{brand.name}. Сделано с Astro.js.
		</div>
	</div>
</footer>
