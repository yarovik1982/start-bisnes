---
interface Props {
  title: string;
}

const { title } = Astro.props;

const breadcrumbLabelMap: Record<string, string> = {
  about: 'О нас',
  services: 'Услуги',
  reviews: 'Отзывы',
  blog: 'Блог',
  contact: 'Контакты',
  privacy:'Политика конфиденциальности',
  terms:"Условия использования"
};

const formatBreadcrumbLabel = (segment: string) => {
  const decoded = decodeURIComponent(segment);
  const mapped = breadcrumbLabelMap[decoded.toLowerCase()];
  if (mapped) return mapped;

  return decoded
    .split('-')
    .filter(Boolean)
    .map((word) => word.charAt(0).toLocaleUpperCase('ru-RU') + word.slice(1))
    .join(' ');
};

const segments = Astro.url.pathname
  .split('/')
  .filter(Boolean)
  .map((seg, i, arr) => ({
    label: formatBreadcrumbLabel(seg),
    href: '/' + arr.slice(0, i + 1).join('/'),
    isLast: i === arr.length - 1,
  }));
  
---

<section class="bg-primary py-14 sm:py-16 lg:py-20">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <!-- Breadcrumb -->
    <nav aria-label="Хлебные крошки" class="mb-4">
      <ol class="flex flex-wrap items-center gap-1.5 text-sm text-primary-fg/60">
        <li>
          <a href="/" class="transition-colors hover:text-primary-fg">Главная</a>
        </li>
        {segments.map(({ label, href, isLast }) => (
          <li class="flex items-center gap-1.5">
            <svg class="size-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            {isLast ? (
              <span aria-current="page" class="text-primary-fg">{label}</span>
            ) : (
              <a href={href} class="transition-colors hover:text-primary-fg">{label}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>
    {
      segments.map(({label})=>(
      <h1 class="font-heading text-h1 font-bold uppercase text-primary-fg">
        {label}
      </h1>

      ))
    }
  </div>
</section>
